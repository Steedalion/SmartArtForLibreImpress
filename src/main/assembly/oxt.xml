<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">
    <id>oxt</id>
    <formats>
        <format>zip</format>
    </formats>
    <baseDirectory></baseDirectory>
    <fileSets>
        <!-- Include compiled JAR (shaded with dependencies) -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <includes>
                <include>smartart-${project.version}.jar</include>
            </includes>
            <outputDirectory>/</outputDirectory>
        </fileSet>
        <!-- Include META-INF for extension metadata -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources/META-INF</directory>
            <outputDirectory>/META-INF</outputDirectory>
        </fileSet>
        <!-- Include UNO component descriptor -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources/uno</directory>
            <outputDirectory>/</outputDirectory>
        </fileSet>
        <!-- Include dialogs -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources/dialogs</directory>
            <outputDirectory>/dialogs</outputDirectory>
        </fileSet>
        <!-- Include description.xml -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources</directory>
            <includes>
                <include>description.xml</include>
            </includes>
            <outputDirectory>/</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
